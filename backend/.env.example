# Copy this file to backend/.env and fill in values

# Generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_PYTHON_SECRETS_TOKEN_HEX_32

# SQLite (default, works out of the box locally)
DATABASE_URL=sqlite+aiosqlite:///./anomaly_detection.db

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/anomaly_db

# Allowed frontend origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
